# Copiar a .env en el servidor: cp .env.example .env && nano .env

SECRET_KEY=generar-con-install-vps-sh
DEBUG=0

# IP del VPS (opcional, para pruebas directas)
ALLOWED_HOSTS=127.0.0.1
# Todos los subdominios de este dominio (facugym.sistemgympro.com, etc.)
ALLOWED_HOSTS_PARENT=sistemgympro.com
CSRF_TRUSTED_SUBDOMAIN_SUFFIX=sistemgympro.com

# Dominio público de ESTA instancia (sin barra final)
PUBLIC_BASE_URL=https://facugym.sistemgympro.com

# SQLite — ruta absoluta recomendada en producción
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=/var/www/gym/box.sqlite3

# Twilio (opcional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
TWILIO_WHATSAPP_FROM=

# Email (opcional)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
DEFAULT_FROM_EMAIL=no-reply@facugym.sistemgympro.com
